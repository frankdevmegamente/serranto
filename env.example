# ============================================================
# CONFIGURACIÓN - Copia este archivo como .env y remplaza valores
# ============================================================

# --- Admin Credentials ---
ADMIN_USER=admin
# Genera el hash con: php -r "echo password_hash('tu_password', PASSWORD_BCRYPT);"
ADMIN_PASS_HASH=

# --- PayPal API Keys ---
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_API_URL=https://api-m.paypal.com

# --- Stripe API Keys ---
STRIPE_SECRET_KEY=

# --- Tipo de cambio USD → MXN (para mostrar conversión) ---
TIPO_CAMBIO=20.00
